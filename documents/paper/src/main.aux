\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Agreement matrices between out-of-fold predictions \(\hat  {y}_{\text  {arch}}\) and the calculator label \(y_{\text  {calc}}\) for the models highlighted in Table~\ref {tab:calc-alignment}. Each cell reports a count and its percentage of all 36{,}405 OOF predictions. DF Gradient Boosting is the best individual community predictor and matches the calculator on 23{,}297 predictions (64.0\%); its off-diagonal mass is 9{,}986 below the calculator (27.4\%) and 3{,}122 above it (8.6\%). DF Random Forest is the closest individual model to the calculator, with 25{,}217 exact matches (69.3\%), 8{,}000 below-calculator errors (22.0\%), and 3{,}188 above-calculator errors (8.8\%). The top-3 voting ensemble is the best overall community predictor, with 24{,}264 exact matches (66.7\%), 9{,}788 below-calculator errors (26.9\%), and 2{,}353 above-calculator errors (6.5\%).}}{11}{figure.3}\protected@file@percent }
\newlabel{fig:df-models-ycalc-matrix}{{3}{11}{Agreement matrices between out-of-fold predictions \(\hat {y}_{\text {arch}}\) and the calculator label \(y_{\text {calc}}\) for the models highlighted in Table~\ref {tab:calc-alignment}. Each cell reports a count and its percentage of all 36{,}405 OOF predictions. DF Gradient Boosting is the best individual community predictor and matches the calculator on 23{,}297 predictions (64.0\%); its off-diagonal mass is 9{,}986 below the calculator (27.4\%) and 3{,}122 above it (8.6\%). DF Random Forest is the closest individual model to the calculator, with 25{,}217 exact matches (69.3\%), 8{,}000 below-calculator errors (22.0\%), and 3{,}188 above-calculator errors (8.8\%). The top-3 voting ensemble is the best overall community predictor, with 24{,}264 exact matches (66.7\%), 9{,}788 below-calculator errors (26.9\%), and 2{,}353 above-calculator errors (6.5\%)}{figure.3}{}}
