\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Calculator-alignment highlights. The raw-label row compares \(y_{\text  {arch}}\) directly with \(y_{\text  {calc}}\); all other rows compare a model's out-of-fold predictions \(\hat  {y}_{\text  {arch}}\) with \(y_{\text  {calc}}\). In the Source column, GB is Gradient Boosting, RF is Random Forest, DT is Decision Tree, and NB is Naive Bayes. Columns: \textit  {Exact} --- fraction of rows where \(\hat  {y}_{\text  {arch}} = y_{\text  {calc}}\); \(\pm 1\) --- fraction within one bracket; \textit  {Mean $|\Delta |$} --- mean absolute difference; \textit  {F1 calc} --- macro-F1 of the predictions when scored against \(y_{\text  {calc}}\); \textit  {F1 arch} --- macro-F1 against \(y_{\text  {arch}}\) (the supervised target, taken from Table~\ref {tab:nested-results}); \textit  {Gap} --- $|\,\text  {F1 arch} - \text  {Exact}\,|$, measuring how far performance on the community target sits from raw calculator agreement.}}{10}{table.8}\protected@file@percent }
\newlabel{tab:calc-alignment}{{8}{10}{Calculator-alignment highlights. The raw-label row compares \(y_{\text {arch}}\) directly with \(y_{\text {calc}}\); all other rows compare a model's out-of-fold predictions \(\hat {y}_{\text {arch}}\) with \(y_{\text {calc}}\). In the Source column, GB is Gradient Boosting, RF is Random Forest, DT is Decision Tree, and NB is Naive Bayes. Columns: \textit {Exact} --- fraction of rows where \(\hat {y}_{\text {arch}} = y_{\text {calc}}\); \(\pm 1\) --- fraction within one bracket; \textit {Mean $|\Delta |$} --- mean absolute difference; \textit {F1 calc} --- macro-F1 of the predictions when scored against \(y_{\text {calc}}\); \textit {F1 arch} --- macro-F1 against \(y_{\text {arch}}\) (the supervised target, taken from Table~\ref {tab:nested-results}); \textit {Gap} --- $|\,\text {F1 arch} - \text {Exact}\,|$, measuring how far performance on the community target sits from raw calculator agreement}{table.8}{}}
