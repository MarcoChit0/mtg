\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Calculator-alignment highlights. The raw-label row compares \(y_{\text  {arch}}\) directly with \(y_{\text  {calc}}\); all other rows compare a model's out-of-fold predictions \(\hat  {y}_{\text  {arch}}\) with \(y_{\text  {calc}}\). In the Source column, GB is Gradient Boosting, RF is Random Forest, and DT is Decision Tree. Columns: \textit  {Exact} --- fraction of rows where \(\hat  {y}_{\text  {arch}} = y_{\text  {calc}}\); \(\pm 1\) --- fraction within one bracket; \textit  {Mean $|\Delta |$} --- mean absolute difference; \textit  {F1 calc} --- macro-F1 of the predictions when scored against \(y_{\text  {calc}}\); \textit  {F1 arch} --- macro-F1 against \(y_{\text  {arch}}\) (the supervised target, taken from Table~\ref {tab:nested-results}).}}{10}{table.7}\protected@file@percent }
\newlabel{tab:calc-alignment}{{7}{10}{Calculator-alignment highlights. The raw-label row compares \(y_{\text {arch}}\) directly with \(y_{\text {calc}}\); all other rows compare a model's out-of-fold predictions \(\hat {y}_{\text {arch}}\) with \(y_{\text {calc}}\). In the Source column, GB is Gradient Boosting, RF is Random Forest, and DT is Decision Tree. Columns: \textit {Exact} --- fraction of rows where \(\hat {y}_{\text {arch}} = y_{\text {calc}}\); \(\pm 1\) --- fraction within one bracket; \textit {Mean $|\Delta |$} --- mean absolute difference; \textit {F1 calc} --- macro-F1 of the predictions when scored against \(y_{\text {calc}}\); \textit {F1 arch} --- macro-F1 against \(y_{\text {arch}}\) (the supervised target, taken from Table~\ref {tab:nested-results})}{table.7}{}}
