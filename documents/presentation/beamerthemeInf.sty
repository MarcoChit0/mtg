\setbeamertemplate{navigation symbols}{%
    \usebeamerfont{footline}%
    \usebeamercolor[fg]{footline}%
    \hspace{1em}%
    \insertframenumber/\inserttotalframenumber%
    \vspace{0.3em}%
}
\setbeamerfont{footline}{size=\footnotesize}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%%%%%              Title Page               %%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\setlength{\InfOutterTitleWidth}{0.35\paperwidth}
\setlength{\InfOutterTitleRightMargin}{8pt}
\setlength{\InfOutterTitleBottomMargin}{5pt}

\newcommand{\InfSubtitleSep}{~---~}

\setbeamertemplate{title page}{%
    \begin{beamercolorbox}[wd=\paperwidth,ht=\paperheight,center]{title}%
    \raisebox{0pt}[0pt][0pt]{%
            \begin{pgfpicture}{0pt}{0pt}{\paperwidth}{\paperheight}
            \pgfrect[fill]
                {\pgfpoint{0.00\paperwidth}{0.215\paperheight}}
                {\pgfpoint{1.00\paperwidth}{0.785\paperheight}}
            \color{InfRed}
            \pgfrect[fill]
                {\pgfpoint{0.3\paperwidth}{0.200\paperheight}}
                {\pgfpoint{0.55\paperwidth}{0.015\paperheight}}
            \pgfputat
                {\pgfpoint{0.3\paperwidth}{0.215\paperheight+2\InfOutterTitleBottomMargin}}
                {\pgfbox[left,bottom]{%
                    \begin{minipage}[t][0.785\paperheight][b]{0.6\paperwidth-2\InfOutterTitleRightMargin}%
                        \vfill
                        \vspace{2em}\hspace{.06\paperwidth}
                        \includegraphics[width=0.3\paperwidth]{inf-logo-dark.pdf}
                        \vfill \raggedright\centering\color{InfLightGray}\normalsize\bfseries{\inserttitle}
                    \end{minipage}
                 }}
            \normalsize
            \pgfputat
                {\pgfpoint{0.0\paperwidth}{0.00\paperheight}}
                {\pgfbox[left,bottom]{
                    \includegraphics[width=0.14\paperwidth]{ufrgs-logo.png}
                }}
            \pgfputat
                {\pgfpoint{0.3\paperwidth}{0.00\paperheight}}
                {\pgfbox[left,bottom]{%
                    \color{InfBlack}
                    \begin{minipage}[t][0.200\paperheight][c]{0.6\paperwidth-2\InfOutterTitleRightMargin}%
                        \insertauthor~\\
                        {
                            \color{InfGray}\insertinstitute~\\
                            \scriptsize%
                            \insertsubtitle%
                            \ifthenelse{\equal{\insertsubtitle}{}}{}{%
                                \ifthenelse{\equal{\insertdate}{}}{}{%
                                    \InfSubtitleSep%
                                }%
                            }%
                            \insertdate%
                        }
                    \end{minipage}
                 }}
        \end{pgfpicture}
    }
    \end{beamercolorbox}
}


