%%%%%%                Others                 %%%%%
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%



\newcommand{\InfTitlePage}[0]{
    \begin{frame}[noframenumbering, plain]
        \titlepage
    \end{frame}
}

\newcommand{\InfContacts}[0]{
    \parbox{\textwidth}{%
        \centering
        {\bfseries \insertauthor}~\\
        {\small \insertinstitute}~\\
        \vspace{30pt}
        \includegraphics[width=0.2\paperwidth]{inf-logo-white.pdf}
    }
}

